PORT=3002
HOST=0.0.0.0

# Realm OIDC/webhook config lives in Postgres (see docs/billing/seed_minimal.sql)

# Postgres connection string (works with PgBouncer)
DATABASE_URI=postgres://user:pass@localhost:5432/billing
# Logical plane id. 'admin' is reserved for Vluna admin plane.
# OSS/Enterprise default should stay 'vluna' for upgrade continuity.
VLUNA_PLANE=vluna
# Optional DB schema for business tables and migration metadata.
# Default: control_plane
VLUNA_DB_SCHEMA=control_plane
# Stripe configuration now lives in realm metadata (see docs/billing/seed_minimal.*)

# Optional: Realm metadata override for importer (JSON string)
# SEED_REALM_METADATA_JSON={"auth":{...},"payments":{...}}
# Or realm-specific: SEED_REALM_METADATA_JSON_DEMO_REALM_1=...
