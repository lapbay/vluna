{
  "name": "@vluna/vluna-core",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "NestJS + Fastify service (per SYSTEM_DECISIONS)",
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "files": [
    "dist",
    "migrations"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./migrations/base": "./migrations/base/index.js",
    "./db": {
      "types": "./dist/db/index.d.ts",
      "default": "./dist/db/index.js"
    },
    "./db/*": {
      "types": "./dist/db/*.d.ts",
      "default": "./dist/db/*.js"
    },
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "dist/*.d.ts"
      ]
    }
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -b --clean tsconfig.build.json && tsc -b tsconfig.build.json",
    "build:watch": "tsc -b --force tsconfig.build.json --watch",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test:roles-cache": "tsx scripts/test-org-roles-cache.ts",
    "db:setup": "tsx src/scripts/run-local-db-setup.ts",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "test": "vitest run -c vitest.config.community.ts",
    "test:community": "vitest run -c vitest.config.community.ts",
    "test:db": "vitest --run -c vitest.config.community.ts --dir tests/postgres",
    "test:api": "vitest --run -c vitest.config.community.ts --dir tests/api",
    "test:all": "pnpm run test:community",
    "vlunactl": "tsx src/scripts/vlunactl.ts",
    "typecheck:tests": "tsc --noEmit -p tests/tsconfig.json",
    "typecheck:all": "pnpm run typecheck && pnpm run typecheck:tests"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@nestjs/common": "^11.1.9",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.9",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/platform-fastify": "^11.1.9",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.5",
    "fastify": "^5.6.2",
    "fastify-raw-body": "^5.0.0",
    "jose": "^5.9.6",
    "kysely": "^0.27.4",
    "pg": "^8.12.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "stripe": "^16.6.0",
    "yaml": "^2.5.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.9",
    "@testcontainers/postgresql": "^11.8.1",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^2.0.16",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "eslint": "^9.9.1",
    "eslint-plugin-import": "^2.29.1",
    "eslint-import-resolver-typescript": "^3.6.1",
    "@types/node": "^24.3.0",
    "vitest": "^2.1.1",
    "@vitest/expect": "^2.1.1",
    "@vitest/runner": "^2.1.1",
    "@vitest/snapshot": "^2.1.1",
    "@vitest/spy": "^2.1.1",
    "eslint-config-prettier": "^9.1.0",
    "pino-pretty": "^11.0.0",
    "supertest": "^7.0.0",
    "testcontainers": "^10.11.3",
    "tsx": "^4.15.7",
    "typescript": "^5.9.2"
  }
}
